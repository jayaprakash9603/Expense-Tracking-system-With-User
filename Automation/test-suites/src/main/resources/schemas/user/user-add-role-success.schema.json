{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "message",
    "user"
  ],
  "properties": {
    "message": {
      "type": "string"
    },
    "user": {
      "type": "object",
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "integer"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "newToken": {
      "type": "string"
    },
    "tokenRefreshRequired": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}

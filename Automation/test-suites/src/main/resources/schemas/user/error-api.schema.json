{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "errorCode",
    "message",
    "status",
    "path",
    "timestamp"
  ],
  "properties": {
    "errorCode": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "status": {
      "type": "integer"
    },
    "path": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "serviceName": {
      "type": "string"
    },
    "details": {
      "type": "string"
    },
    "traceId": {
      "type": "string"
    },
    "fieldErrors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field",
          "message"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "rejectedValue": {},
          "constraint": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

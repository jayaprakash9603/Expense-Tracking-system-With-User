{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "message",
    "fieldErrors"
  ],
  "properties": {
    "message": {
      "type": "string"
    },
    "status": {
      "type": [
        "integer",
        "string"
      ]
    },
    "fieldErrors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "field",
          "message"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "constraint": {
            "type": [
              "string",
              "null"
            ]
          },
          "rejectedValue": {}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

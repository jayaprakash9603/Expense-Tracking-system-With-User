    "mfaEnabled",
    "twoFactorEnabled"
  ],
  "properties": {
    "mfaEnabled": {
      "type": "boolean"
    },
    "twoFactorEnabled": {
      "type": "boolean"
    },
    "remainingBackupCodes": {
      "type": "integer"
    },
    "mfaEnabledAt": {
      "type": [
        "string",
        "null"
      ]
    },
    "activePriority": {
      "type": "string"
    }
  },
  "additionalProperties": true
}

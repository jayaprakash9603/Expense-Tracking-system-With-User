{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "anyOf": [
    { "required": ["method"] },
    { "required": ["authProvider"] }
  ],
  "properties": {
    "method": {
      "type": "string"
    },
    "authProvider": {
      "type": "string"
    },
    "exists": {
      "type": ["boolean", "null"]
    },
    "hasPassword": {
      "type": ["boolean", "null"]
    },
    "emailExists": {
      "type": ["boolean", "null"]
    },
    "twoFactorEnabled": {
      "type": ["boolean", "null"]
    },
    "mfaEnabled": {
      "type": ["boolean", "null"]
    }
  },
  "additionalProperties": true
}
